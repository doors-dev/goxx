package test

import (
	"context"
	"io"
	"time"
	
	"github.com/doors-dev/gox"
	"github.com/doors-dev/goxx"
)

// this should render ~500ms

func render(w io.Writer) error {
	p := gox.NewPrinter(w)
	return Parallel().Print(context.Background(), p)
}

elem Parallel() {
	~>(goxx.Parallel()) <>
		~{
			<-time.After(time.Second / 2)
		}
		~>(goxx.Parallel()) <>
			~{
				<-time.After(time.Second / 2)
			}
			~>(goxx.Parallel()) <>
				~{
					<-time.After(time.Second / 2)
				}
			</>
		</>
	</>
	~>(goxx.Parallel()) <>
		~{
			<-time.After(time.Second / 2)
		}
	</>
	~{
		<-time.After(time.Second / 2)
	}
}
